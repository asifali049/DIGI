# =============================================================================
# APPLICATION
# =============================================================================

NODE_ENV=development
PORT=4000
APP_NAME=DIGI Backend
API_PREFIX=api/v1
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# =============================================================================
# DATABASE
# =============================================================================

DATABASE_URL="postgresql://postgres:password@localhost:5432/digi_agency?schema=public"

# =============================================================================
# JWT
# =============================================================================

JWT_ACCESS_SECRET=replace_with_a_very_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=replace_with_a_different_very_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# =============================================================================
# SECURITY
# =============================================================================

BCRYPT_SALT_ROUNDS=12

COOKIE_SECRET=replace_with_cookie_secret

CORS_ORIGIN=http://localhost:3000

# =============================================================================
# REDIS
# =============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# =============================================================================
# IMAGEKIT
# =============================================================================

IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# =============================================================================
# RESEND EMAIL
# =============================================================================

RESEND_API_KEY=
EMAIL_FROM="DIGI Agency <noreply@example.com>"

# =============================================================================
# STRIPE
# =============================================================================

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# =============================================================================
# RAZORPAY
# =============================================================================

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=info

# =============================================================================
# RATE LIMIT
# =============================================================================

THROTTLE_TTL=60
THROTTLE_LIMIT=100

# =============================================================================
# SWAGGER
# =============================================================================

SWAGGER_ENABLED=true

# =============================================================================
# HEALTH
# =============================================================================

HEALTH_CHECK_PATH=/health

# =============================================================================
# TIMEZONE
# =============================================================================

TZ=Asia/Kolkata